{
	"name": "lll-client",
	"version": "0.1.0",
	"type": "module",
	"scripts": {
		"typecheck": "tsc --noEmit --watch",
		"dev": "node scripts/dev-with-emit.mjs",
		"dev:vite": "vite",
		"dev:emit": "tsc -w --preserveWatchOutput",
		"lll-server": "pnpm exec evidyts --server start --port 58973 --projectPath . --projectClientLink http://localhost:58971",
		"lll-check": "tsc --preserveWatchOutput  && pnpm exec lllts --project tsconfig.json --entry src/Start.lll.ts --clientTunnel http://localhost:58973",
		"build": "tsc && vite build",
		"preview": "vite preview"
	},
	"dependencies": {
		"lit": "^3.2.1",
		"zod": "^4.3.5"
	},
	"devDependencies": {
		"@types/node": "^22.10.1",
		"typescript": "^5.6.3",
		"vite": "^5.4.10",
		"lllts": "file:../.lll/vendor/lllts"
	}
}