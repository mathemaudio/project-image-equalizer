{
	"name": "lll-shared",
	"version": "0.1.0",
	"packageManager": "pnpm@9.15.0",
	"type": "module",
	"main": "./src/index.ts",
	"types": "./src/index.ts",
	"scripts": {
		"typecheck": "tsc --noEmit --watch",
		"dev": "tsc --watch",
		"lll-check": "npm run build && lllts --project tsconfig.json --entry src/index.ts --verbose --noEmit",
		"build": "node ../server/node_modules/typescript/bin/tsc -p tsconfig.json && node -e \"require('node:fs').writeFileSync('dist/package.json', '{\\\"type\\\":\\\"commonjs\\\"}\\n')\"",
		"i": "pnpm i"
	},
	"dependencies": {
		"zod": "^4.3.5",
		"typescript": "^5.6.3"
	}
}